{
  "name": "thalia",
  "private": false,
  "version": "1.1.2",
  "type": "module",
  "description": "Yet another server framework for serving websites",
  "main": "./server/index.ts",
  "types": "./server/index.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./server/index.ts",
      "import": "./server/index.ts",
      "default": "./server/index.ts"
    },
    "./cli": {
      "types": "./server/cli.ts",
      "import": "./server/cli.ts",
      "default": "./server/cli.ts"
    },
    "./types": {
      "types": "./server/types.ts",
      "import": "./server/types.ts",
      "default": "./server/types.ts"
    },
    "./server": {
      "types": "./server/server.ts",
      "import": "./server/server.ts",
      "default": "./server/server.ts"
    },
    "./website": {
      "types": "./server/website.ts",
      "import": "./server/website.ts",
      "default": "./server/website.ts"
    },
    "./models": {
      "types": "./models/index.ts",
      "import": "./models/index.ts",
      "default": "./models/index.ts"
    },
    "./security-models": {
      "types": "./models/security-models.ts",
      "import": "./models/security-models.ts",
      "default": "./models/security-models.ts"
    },
    "./security": {
      "types": "./server/security/index.ts",
      "import": "./server/security/index.ts",
      "default": "./server/security/index.ts"
    },
    "./controllers": {
      "types": "./server/controllers.ts",
      "import": "./server/controllers.ts",
      "default": "./server/controllers.ts"
    },
    "./mail": {
      "types": "./server/mail.ts",
      "import": "./server/mail.ts",
      "default": "./server/mail.ts"
    },
    "./util": {
      "types": "./server/util.ts",
      "import": "./server/util.ts",
      "default": "./server/util.ts"
    },
    "./images": {
      "types": "./server/images/index.ts",
      "import": "./server/images/index.ts",
      "default": "./server/images/index.ts"
    },
    "./testing": {
      "types": "./tests/Integration/helpers.ts",
      "import": "./tests/Integration/helpers.ts",
      "default": "./tests/Integration/helpers.ts"
    },
    "./tests/Integration/helpers": {
      "types": "./tests/Integration/helpers.ts",
      "import": "./tests/Integration/helpers.ts",
      "default": "./tests/Integration/helpers.ts"
    }
  },
  "bin": {
    "thalia": "./server/cli.ts",
    "thalia-develop": "./bin/develop.ts",
    "thalia-sitemap": "./bin/sitemap.ts"
  },
  "files": [
    "server/**/*",
    "models/**/*",
    "bin/**/*",
    "public/**/*",
    "src/**/*",
    "tests/Integration/helpers.ts",
    "AGENTS.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "bun server/cli.ts",
    "pm2:start": "pm2 startOrReload pm2.config.json",
    "pm2:stop": "pm2 delete pm2.config.json",
    "typecheck": "bunx tsc --noEmit -p tsconfig.json",
    "dev": "bun bin/develop.ts",
    "build:scss": "bun bin/build-scss.ts",
    "sitemap": "bun bin/sitemap.ts",
    "sitemap:generate": "bun scripts/generate-sitemaps.ts",
    "sitemap:smoke": "bun scripts/smoke-sitemap.ts",
    "test": "bun test tests",
    "test:integration:database": "SKIP_DATABASE_TESTS=0 bun test tests/Integration/database-online.test.ts tests/Integration/example-auth-images-notes-blob.test.ts tests/Integration/example-auth-profile.test.ts",
    "test:integration:example-auth": "SKIP_EXAMPLE_AUTH_TESTS=0 bun test tests/Integration/request-handler.test.ts",
    "test:unit": "bun test tests/Unit",
    "test:integration": "SKIP_DATABASE_TESTS=1 SKIP_EXAMPLE_AUTH_TESTS=1 bun test tests/Integration"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "bun": "^1.3.14",
    "cheerio": "^1.2.0",
    "drizzle-orm": "^0.45.2",
    "formidable": "^3.5.4",
    "get-port-please": "^3.2.0",
    "handlebars": "^4.7.9",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.5",
    "marked-highlight": "^2.2.4",
    "mysql2": "^3.22.5",
    "nodemailer": "^9.0.1",
    "sass": "1.101.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/formidable": "^3.5.1",
    "@types/nodemailer": "^8.0.1",
    "bun-types": "1.3.14",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.9.4"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/david-ma/Thalia.git"
  },
  "author": "David Ma",
  "license": "GPL-3.0-only",
  "bugs": {
    "url": "https://github.com/david-ma/Thalia/issues"
  },
  "homepage": "https://github.com/david-ma/Thalia#readme"
}
