{{!-- Modal detail for one portfolio/service item (expects id, title, subheading, image, description HTML). --}}
<style>
  @media (max-width: 767.98px) {
    .portfolio-modal .modal-image-ratio { --bs-aspect-ratio: 50%; }
  }

  @media (min-width: 768px) {
    .portfolio-modal .modal-image-ratio { --bs-aspect-ratio: 100%; }
  }

  .portfolio-modal.modal .modal-content {
    padding-top: 0;
    padding-bottom: 0;
  }
</style>
<div class="portfolio-modal modal fade" id="modal-{{id}}" tabindex="-1" role="dialog"
  aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content">
      <button type="button" class="btn-close ms-auto me-2 mt-2" data-bs-dismiss="modal" aria-label="Close"></button>
      <div class="container py-3">
        <div class="row justify-content-center">
          <div class="col-12 col-lg-10">
            <div class="modal-body p-0">
              <div class="row g-3">
                <div class="col-12 col-md-5">
                  <div class="ratio modal-image-ratio">
                    <img class="w-100 h-100" style="object-fit: cover; object-position: center;" src="{{image}}"
                      alt="{{title}}" />
                  </div>
                </div>
                <div class="col-12 col-md-7">
                  <h3 class="h4 h3-md">{{title}}</h3>
                  {{#if subheading}}
                  <p class="text-muted small mb-3 mb-md-2">{{subheading}}</p>
                  {{/if}}
                  <div class="small small-md">
                    {{{description}}}
                  </div>
                  <div class="mt-3">
                    {{#if modalPrimaryHref}}
                      <a class="btn btn-primary" href="{{modalPrimaryHref}}">{{#if modalPrimaryLabel}}{{modalPrimaryLabel}}{{else}}Get in touch{{/if}}</a>
                    {{else}}
                      <button class="btn btn-primary" data-bs-dismiss="modal" type="button">{{#if modalPrimaryLabel}}{{modalPrimaryLabel}}{{else}}Contact{{/if}}</button>
                    {{/if}}
                    <button class="btn btn-outline-secondary" data-bs-dismiss="modal" type="button">Close</button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
