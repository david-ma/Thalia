{{!-- Markdown pages: highlight.js line numbers + Mermaid.js. --}}
{{!-- Syntax highlighting is done server-side (marked-highlight); theme + line-number styles in markdown.scss. --}}
{{!-- Client-side highlight.js is only used by the line-numbers plugin (same major version as server). --}}

<link rel="stylesheet" href="/css/markdown.css">
<script src="/js/vendor/highlight.11.7.0min.js"></script>
<script src="/js/vendor/highlight.js-line-numbers.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>
<script>
  (function() {
    if (typeof hljs !== 'undefined' && hljs.initLineNumbersOnLoad) {
      hljs.initLineNumbersOnLoad();
    }
    if (typeof mermaid !== 'undefined') {
      mermaid.initialize({ startOnLoad: true });
    }
  })();
</script>
