{{!-- Explain guest / user / admin model at a glance (#guards). --}}
<section class="page-section" id="guards">
  <div class="container">
    <div class="text-center mb-5">
      <h2 class="section-heading text-uppercase">Route guards</h2>
      <p class="section-subheading text-muted">
        Matches on path prefixes attach permissions for <strong>guest</strong>, signed-in users, and <strong>admin</strong>.</p>
    </div>
    <div class="row justify-content-center g-4">
      <div class="col-md-4">
        <div class="timeline-panel border rounded shadow-sm h-100 p-4 bg-light">
