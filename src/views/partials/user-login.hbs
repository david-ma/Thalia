<div class="login">
  <h2 class="h4 mb-1">Log in</h2>
  <p class="text-muted small mb-3">Sign in with your account email and password.</p>

  {{#if message}}
    <p class="message" role="status">{{message}}</p>
  {{/if}}
  {{#if error}}
    <p class="error" role="alert">{{error}}</p>
  {{/if}}

  <form action="/logon" method="post" autocomplete="on">
    {{> input field="Email" helpText="Your email" type="email"}}
    {{> input field="Password" type="password" helpText="Your password"}}
    <input id="Redirect" name="Redirect" type="hidden" />
    <button id="loginButton" type="submit" class="btn btn-primary w-100">Log in</button>
  </form>

  <ul class="auth-links small">
    <li><a href="/newUser">Create an account</a></li>
    <li><a href="/forgotPassword">Forgot password?</a></li>
  </ul>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var redirect = document.getElementById('Redirect')
    if (!redirect || !window.location.search) return
    var params = new URLSearchParams(window.location.search)
    var r = params.get('redirect')
    if (r) redirect.value = r
  })
</script>
