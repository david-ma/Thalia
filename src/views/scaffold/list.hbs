<h1>{{controllerName}}{{#if readOnly}} <span class="text-muted small">(read-only)</span>{{/if}}</h1>

<div class="datatables-table-container">
  <table id="myTable"></table>
</div>

{{#unless readOnly}}
<button onclick="window.location.href='/{{controllerName}}/new'">Create New {{controllerName}}</button>
{{/unless}}

<script>
  var crudTable = null;

  function crudDownloadCsv() {
    if (!crudTable) return;
    window.location.href = '/{{controllerName}}/csv?' + $.param(crudTable.ajax.params());
  }

  function crudLayoutActions() {
    var actions = document.createElement('div');
    actions.className = 'dt-crud-actions d-inline-flex gap-2 align-items-center ms-2';
    var btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'btn btn-sm btn-outline-secondary';
    btn.textContent = 'Download CSV';
    btn.addEventListener('click', crudDownloadCsv);
    actions.appendChild(btn);
    return actions;
  }

  $.ajax('/{{controllerName}}/columns')
    .then(function (columns) {

      columns.forEach(addRenders)

      var tableOptions = {
        ajax: {
          url: '/{{controllerName}}/json',
          dataSrc: 'data',
          data: function (d) {
            delete d.columns;
            return d
          }
        },
        order: [[0, 'desc']],
        processing: true,
        serverSide: true,
        columns: columns
      };

      {{#if downloadableCsv}}
      tableOptions.layout = {
        topStart: ['pageLength', crudLayoutActions],
        topEnd: 'search',
        bottomStart: 'info',
        bottomEnd: 'paging',
      };
      {{/if}}

      crudTable = $('#myTable').DataTable(tableOptions);

    })

  function addRenders(column) {
    const links = []

    {{#each links}}
    links.push({{{this}}})
    {{/each}}

    links.forEach(function (link) {
      if (link.attribute.fieldName === column.data) {
        column.render = function (data, type, row, meta) {
          let name = row[link.name].name || data
          return `<a href="/${link.name.toLowerCase()}/${data}">${name}</a>`
        }
      }
    })

    if (column.data === '{{ primaryKey }}') {
      column.render = function (data, type, row, meta) {
        const id = encodeURIComponent(String(data))
        {{#if readOnly}}
        return `<span>${id}</span>`
        {{else}}
        return `<a href="/{{controllerName}}/show/${id}">${id}</a>
        <span style="float:right"><a href="/{{controllerName}}/edit/${id}" aria-label="Edit ${id}">📝</a></span>`
        {{/if}}
      }
    }

    if (column.type === 'object') {
      column.render = function (data, type, row, meta) {
        return `<p class="blob">${JSON.stringify(data)}</p>`
      }
    }

    if (column.type === 'date') {
      column.render = function (data, type, row, meta) {

        let time = new Date(data).toLocaleTimeString()
        let date = new Date(data).toLocaleDateString()
        return `${time} ${date}`
      }
    }
  }

</script>
