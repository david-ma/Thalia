<h1>This is a Show page</h1>

<a href="/{{controllerName}}">Back to table {{title}}</a>

<div class="crud-table">
  <table></table>
</div>

<button id="editButton" onclick="window.location.href='/{{controllerName}}/edit/{{id}}'">Edit</button>

<script>
  var data = {{{ json }}} || {}

  const rows = d3.select("table")
    .selectAll("tr")
    .data(Object.entries(data))
    .enter()
    .append("tr")

  rows.append("td").text(function ([key]) { return String(key) })

  rows.append("td").each(function ([key, value]) {
    const cell = d3.select(this)
    if (value && (key === 'image' || key === 'photo')) {
      cell.append('img').attr('src', String(value))
      return
    }
    if (typeof value === 'object') {
      cell.text(JSON.stringify(value))
      return
    }
    cell.text(value == null ? '' : String(value))
  })

</script>