<div class="login">
  <h2 class="h4 mb-1">Forgot password</h2>
  <p class="text-muted small mb-3">We will email you a link to reset your password if that address is registered.</p>
  <form action="/forgotPassword" method="post">
    {{> input field="email" type="email" helpText="Account email" required=true}}
    <button type="submit" class="btn btn-primary w-100">Send reset link</button>
  </form>
  {{#if message}}
    <p class="message mt-3" role="status">{{message}}</p>
  {{/if}}
  {{#if error}}
    <p class="error mt-3" role="alert">{{error}}</p>
  {{/if}}
  <p class="small mt-3 mb-0"><a href="/logon">Back to sign in</a></p>
</div>
