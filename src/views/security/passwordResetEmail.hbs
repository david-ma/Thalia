{{!--
  Password reset email body (HTML for multipart/alternative).
  Override this partial in your project (e.g. websites/yoursite/src/views/security/passwordResetEmail.hbs).

  Data:
  - preheader: short summary for inbox preview (also emitted as hidden preheader markup)
  - resetUrl: full URL to the reset-password page (e.g. https://example.com/resetPassword?token=...)
  - siteName: name of the website (from website.name)
  - email: recipient email (for personalisation)
--}}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reset your password</title>
</head>
<body style="margin:0;padding:0;background-color:#f4f4f5;">
  {{!-- Preheader: shown in inbox preview; hidden in the opened message in most clients. --}}
  <div style="display:none;font-size:1px;line-height:1px;max-height:0;max-width:0;opacity:0;overflow:hidden;mso-hide:all;">
    {{preheader}}&#8203;&zwnj;&nbsp;&#8203;&zwnj;&nbsp;&#8203;&zwnj;&nbsp;&#8203;&zwnj;&nbsp;&#8203;&zwnj;&nbsp;
  </div>
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color:#f4f4f5;">
    <tr>
      <td align="center" style="padding:24px 12px;">
        <table role="presentation" width="600" cellspacing="0" cellpadding="0" border="0" style="max-width:600px;width:100%;background-color:#ffffff;border-radius:8px;overflow:hidden;">
          <tr>
            <td style="padding:28px 24px;font-family:system-ui,-apple-system,'Segoe UI',Roboto,'Helvetica Neue',Arial,sans-serif;font-size:16px;line-height:1.5;color:#1a1a1a;">
              <p style="margin:0 0 16px;">Hi,</p>
              <p style="margin:0 0 16px;">Someone requested a password reset{{#if email}} for <strong>{{email}}</strong>{{/if}}.</p>
              <p style="margin:0 0 16px;">To choose a new password, use this button (or the plain link below if the button does not work):</p>
              <p style="margin:0 0 20px;text-align:center;">
                <a href="{{resetUrl}}" style="display:inline-block;padding:12px 20px;background-color:#0d6efd;color:#ffffff;text-decoration:none;border-radius:6px;font-weight:600;">Reset password</a>
              </p>
              <p style="margin:0 0 8px;font-size:14px;color:#555;">Or copy and paste this URL into your browser:</p>
              <p style="margin:0 0 20px;font-size:14px;word-break:break-all;color:#0d6efd;">{{resetUrl}}</p>
              <p style="margin:0 0 16px;font-size:14px;color:#555;">This link expires in <strong>1 hour</strong>. If you did not request a reset, you can ignore this email; your password will stay the same.</p>
              {{#if siteName}}
              <p style="margin:24px 0 0;padding-top:16px;border-top:1px solid #e5e5e5;font-size:14px;color:#666;">— {{siteName}}</p>
              {{/if}}
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
