<div class="box">
  <h2>Reset Password</h2>

  {{! Fail state: invalid or expired token — no form, clear CTA to request new link }}
  {{#if error}}
    {{#unless token}}
  <div class="alert alert-warning" role="alert">
    <h3 class="alert-heading">Link invalid or expired</h3>
    <p class="mb-0">{{error}}</p>
  </div>
  {{#if forgotPasswordUrl}}
  <p class="mt-3">
    <a href="{{forgotPasswordUrl}}" class="btn btn-primary">Request a new reset link</a>
  </p>
  <p class="text-muted small">We’ll send a new link to your email. Links expire after one hour.</p>
  {{/if}}
    {{/unless}}
  {{/if}}

  {{! Success state: valid token — show form (with optional inline error from validation) }}
  {{#if token}}
  {{#if error}}
  <div class="alert alert-danger" role="alert">{{error}}</div>
  {{/if}}
  <p class="text-muted">Enter your new password below. It must be at least 6 characters.</p>
  <form action="/resetPassword" method="post">
    <input type="hidden" name="token" value="{{token}}" />
    <div class="mb-3">
      <label for="password" class="form-label">New password</label>
      <input type="password" id="password" name="password" class="form-control" required minlength="6" autocomplete="new-password" />
    </div>
    <div class="mb-3">
      <label for="confirmPassword" class="form-label">Confirm new password</label>
      <input type="password" id="confirmPassword" name="confirmPassword" class="form-control" required minlength="6" autocomplete="new-password" />
    </div>
    <button type="submit" class="btn btn-primary">Set password</button>
  </form>
  {{/if}}

  {{! When we have token but no error, show optional link to request new link anyway }}
  {{#if token}}
  {{#if forgotPasswordUrl}}
  <p class="mt-3 small"><a href="{{forgotPasswordUrl}}">Use a different reset link</a></p>
  {{/if}}
  {{/if}}
</div>
