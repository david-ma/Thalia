<div class="login">
  <h2 class="h4 mb-1">First-time setup</h2>
  {{#if error}}
    <p class="error" role="alert">{{error}}</p>
  {{/if}}
  <p class="text-muted small mb-3">
    No administrator exists yet. Create the first account — on this demo site, the first registration is assigned the
    <strong>admin</strong> role.
  </p>
  <p class="mb-0">
    <a class="btn btn-primary w-100" href="/newUser">Create administrator</a>
  </p>
  <p class="small mt-3 mb-0"><a href="/logon">Already registered? Log in</a></p>
</div>
