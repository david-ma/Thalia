<div class="login mx-auto">
  <h2 class="h5 mb-3">Enter password</h2>
  <form action="{{ route }}" method="post" class="d-flex flex-column gap-2">
    <div>
      <label class="form-label" for="route-guard-password">Password</label>
      <input
        id="route-guard-password"
        class="form-control"
        type="password"
        name="password"
        placeholder="Password"
        autocomplete="current-password"
        autofocus
        required
      />
    </div>
    <button type="submit" class="btn btn-primary">Continue</button>
    {{#if message}}
      <p class="error mb-0" role="alert">{{message}}</p>
    {{/if}}
  </form>
</div>
